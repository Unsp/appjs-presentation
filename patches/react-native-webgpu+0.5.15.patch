@@ -108,6 +108,28 @@ VideoFrameHandle copyLatestFrame() override {
   void play() override { [_player play]; }
   void pause() override { [_player pause]; }
 
+  double getCurrentTimeSeconds() override {
+    return CMTimeGetSeconds(_player.currentTime);
+  }
+
+  double getDurationSeconds() override {
+    AVPlayerItem *item = _player.currentItem;
+    if (!item) {
+      return 0.0;
+    }
+    CMTime duration = item.duration;
+    if (CMTIME_IS_NUMERIC(duration)) {
+      return CMTimeGetSeconds(duration);
+    }
+    return 0.0;
+  }
+
+  void seekToSeconds(double seconds) override {
+    [_player seekToTime:CMTimeMakeWithSeconds(seconds, 600)
+        toleranceBefore:kCMTimeZero
+         toleranceAfter:kCMTimeZero];
+  }
+
 private:
   AVPlayer *_player;
   AVPlayerItemVideoOutput *_output;
