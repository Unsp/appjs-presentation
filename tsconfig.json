{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "@webgpu/types"
    ],
    "paths": {
      "~app": [
        "./src/app"
      ],
      "~app-root": [
        "./src/app-root"
      ],
      "~app/*": [
        "./src/app/*"
      ],
      "~app-root/*": [
        "./src/app-root/*"
      ],
      "~screens/*": [
        "./src/screens/*"
      ],
      "~features/*": [
        "./src/features/*"
      ],
      "~shared/*": [
        "./src/shared/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "slides",
    "slides/dist",
    ".tamagui"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
